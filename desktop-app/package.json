{
  "name": "lagosta-tools",
  "version": "1.0.0",
  "description": "Lagosta Tools - Agendador de Posts",
  "main": "dist-electron/main.js",
  "author": "Studio Lagosta",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "npm run build",
    "package": "npm run build:electron && electron-builder",
    "package:mac": "npm run build:electron && electron-builder --mac",
    "package:win": "npm run build:electron && electron-builder --win",
    "publish:mac": "npm run build:electron && electron-builder --mac --publish always",
    "release": "npm version patch && npm run publish:mac",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint src electron --ext .ts,.tsx"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.60.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "konva": "^10.2.0",
    "lucide-react": "^0.460.0",
    "p-limit": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.14",
    "react-router-dom": "^6.28.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.0",
    "use-image": "^1.1.4",
    "zustand": "^5.0.0",
    "sharp": "^0.33.5",
    "@napi-rs/canvas": "^0.1.95"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.studiolagosta.tools",
    "productName": "Lagosta Tools",
    "copyright": "Copyright © 2025 Studio Lagosta",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Office"
    },
    "dmg": {
      "title": "Lagosta Tools",
      "backgroundColor": "#0a0a0a",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@napi-rs/canvas/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "publish": {
      "provider": "github",
      "owner": "studiolagosta",
      "repo": "lagosta-tools",
      "releaseType": "release"
    }
  }
}
