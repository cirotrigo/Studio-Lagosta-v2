{
  "name": "lagosta-tools",
  "version": "1.0.0",
  "description": "Studio Lagosta — Desktop Scheduler",
  "main": "dist-electron/main.js",
  "author": "Studio Lagosta",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "npm run build && tsc -p tsconfig.electron.json",
    "package": "npm run build:electron && electron-builder",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint src electron --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "@tanstack/react-query": "^5.60.0",
    "zustand": "^5.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.0",
    "sonner": "^1.7.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.33.5",
    "vite": "^6.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1",
    "typescript": "^5.7.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.10.2",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "@fontsource/inter": "^5.1.0"
  },
  "build": {
    "appId": "com.studiolagosta.tools",
    "productName": "Lagosta Tools",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "icon": "resources/icon.icns"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
